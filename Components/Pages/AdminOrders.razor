@page "/admin/orders"
@using CakeFlowerShop.Data
@using CakeFlowerShop.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject ApplicationDbContext DbContext
@rendermode InteractiveServer

<PageTitle>Manage Orders - Blossom & Bake</PageTitle>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="section-title">Customer Orders</h2>
        <button class="btn btn-outline-primary" @onclick="RefreshOrders">Refresh List</button>
    </div>

    @if (orders == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Loading orders...</p>
        </div>
    }
    else if (!orders.Any())
    {
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-box-open fa-3x mb-3"></i>
            <h4>No orders found yet.</h4>
            <p>Orders will appear here once customers start checking out.</p>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle bg-white">
                <thead class="bg-light">
                    <tr>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Items</th>
                        <th>Total</th>
                        <th>Payment</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in orders)
                    {
                        <tr>
                            <td>@order.OrderDate.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                            <td>
                                <div><strong>@order.CustomerName</strong></div>
                                <div class="small text-muted">@order.CustomerEmail</div>
                                <div class="small text-muted text-truncate" style="max-width: 150px;">@order.ShippingAddress</div>
                            </td>
                            <td>
                                @foreach (var item in order.Items)
                                {
                                    <div class="small">@item.Quantity x @(item.Product?.Name ?? "Product")</div>
                                }
                            </td>
                            <td><strong>₱@order.TotalAmount.ToString("0.00")</strong></td>
                            <td>
                                <span class="badge @(order.Payment?.Status == PaymentStatus.Paid ? "bg-success" : "bg-warning")">
                                    @order.Payment?.Method (@order.Payment?.Status)
                                </span>
                            </td>
                            <td>
                                <select class="form-select form-select-sm" value="@order.Status" @onchange="(e) => UpdateStatus(order, e)">
                                    @foreach (var status in Enum.GetValues<OrderStatus>())
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteOrder(order)">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<Order>? orders;

    protected override async Task OnInitializedAsync()
    {
        await RefreshOrders();
    }

    private async Task RefreshOrders()
    {
        orders = await DbContext.Orders
            .Include(o => o.Items)
                .ThenInclude(oi => oi.Product)
            .Include(o => o.Payment)
            .OrderByDescending(o => o.OrderDate)
            .ToListAsync();
    }

    private async Task UpdateStatus(Order order, ChangeEventArgs e)
    {
        if (Enum.TryParse<OrderStatus>(e.Value?.ToString(), out var newStatus))
        {
            order.Status = newStatus;
            await DbContext.SaveChangesAsync();
        }
    }

    private async Task DeleteOrder(Order order)
    {
        DbContext.Orders.Remove(order);
        await DbContext.SaveChangesAsync();
        await RefreshOrders();
    }
}
