@page "/report"
@inject NavigationManager NavigationManager

<PageTitle>Report an Issue - Blossom & Bake</PageTitle>

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4" style="font-family: 'Playfair Display', serif;">Report an Issue</h2>
                    <p class="text-center text-muted mb-4">We are sorry to hear you had an issue with your order. Please fill out the form below and our team will get back to you within 24 hours to process your refund or replacement.</p>

                    @if (isSubmitted)
                    {
                        <div class="alert alert-success text-center py-4" role="alert">
                            <h4 class="alert-heading mb-3"><i class="bi bi-check-circle-fill text-success fs-1"></i><br/>Report Submitted!</h4>
                            <p>Thank you for letting us know. Your report (ID: <strong>#@reportId</strong>) has been successfully submitted.</p>
                            <hr class="my-4">
                            <p class="mb-0">Our customer service team will contact you shortly via email to process your request.</p>
                            <button class="btn btn-primary mt-4" @onclick="GoHome">Return to Home</button>
                        </div>
                    }
                    else
                    {
                        <form @onsubmit="SubmitReport">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Full Name</label>
                                    <input type="text" class="form-control p-2" required placeholder="John Doe" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Email Address</label>
                                    <input type="email" class="form-control p-2" required placeholder="john@example.com" />
                                </div>
                            </div>
                            
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Order Number</label>
                                    <input type="text" class="form-control p-2" required placeholder="e.g. ORD-12345" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label text-muted small fw-bold text-uppercase">Issue Type</label>
                                    <select class="form-select p-2" required>
                                        <option value="" disabled selected>Select an issue...</option>
                                        <option value="Damaged">Product was damaged</option>
                                        <option value="WrongItem">Received the wrong item</option>
                                        <option value="Quality">Poor quality / Not as described</option>
                                        <option value="Missing">Missing items</option>
                                        <option value="Other">Other</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label text-muted small fw-bold text-uppercase">Product Name(s)</label>
                                <input type="text" class="form-control p-2" required placeholder="Which product(s) had the issue?" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label text-muted small fw-bold text-uppercase">Description of Issue</label>
                                <textarea class="form-control p-2" rows="4" required placeholder="Please provide details about the issue..."></textarea>
                            </div>

                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-primary btn-lg p-3" style="font-weight: 500; letter-spacing: 1px;">SUBMIT REPORT</button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool isSubmitted = false;
    private string reportId = "";

    private void SubmitReport()
    {
        // Generate a random report ID
        var random = new Random();
        reportId = "REP-" + random.Next(10000, 99999);
        isSubmitted = true;
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("");
    }
}
