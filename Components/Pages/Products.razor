@page "/products"
@using CakeFlowerShop.Data
@using CakeFlowerShop.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@attribute [Authorize]
@inject ApplicationDbContext DbContext
@inject CartService CartService
@inject IJSRuntime JS

<PageTitle>Blossom & Bake - Shop</PageTitle>

<div class="container mb-5" id="shop">
    <h2 class="section-title mt-5">All Products</h2>

    <div class="search-container mb-4">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="search-box">
                    <i class="fas fa-search search-icon"></i>
                    <input type="text" class="form-control" placeholder="Search for cakes, flowers, or chocolates..." 
                           @bind="searchTerm" @bind:event="oninput" />
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(searchTerm))
    {
        <p class="text-muted text-center mb-4">
            Showing results for "<strong>@searchTerm</strong>" (@FilteredProducts.Count() found)
        </p>
    }

    @if (products == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!FilteredProducts.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-search fa-3x text-muted mb-3"></i>
            <h3>No products found</h3>
            <p class="text-muted">We couldn't find any products matching "@searchTerm". Try a different search term.</p>
            <button class="btn btn-outline-primary mt-3" @onclick='() => searchTerm = ""'>Clear Search</button>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in FilteredProducts)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="product-card">
                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "https://via.placeholder.com/300x250?text=No+Image" : product.ImageUrl)" class="product-img" alt="@product.Name" />
                        <div class="product-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h3 class="product-title">@product.Name</h3>
                                <span class="badge-category">@product.Category.ToString()</span>
                            </div>
                            <p class="product-desc">@product.Description</p>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <div class="product-price">₱@product.Price.ToString("0.00")</div>
                                <button class="btn btn-primary btn-sm" @onclick="() => AddToCart(product)" disabled="@(addingProductId == product.Id)">
                                    @if (addingProductId == product.Id)
                                    {
                                        <span>Added!</span>
                                    }
                                    else
                                    {
                                        <span>Add to Cart</span>
                                    }
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
@code {
    private List<Product>? products;
    private string searchTerm = "";
    private int addingProductId;

    private IEnumerable<Product> FilteredProducts => 
        string.IsNullOrWhiteSpace(searchTerm) 
            ? products ?? new List<Product>() 
            : (products ?? new List<Product>()).Where(p => 
                p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
                p.Description.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                p.Category.ToString().Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        products = await DbContext.Products.ToListAsync();
    }

    private async Task AddToCart(Product product)
    {
        CartService.AddToCart(product);
        
        // Visual feedback
        addingProductId = product.Id;
        StateHasChanged();
        
        await Task.Delay(2000);
        addingProductId = 0;
        StateHasChanged();
    }
}
