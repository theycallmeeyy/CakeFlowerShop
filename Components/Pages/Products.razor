@page "/products"
@using CakeFlowerShop.Data
@using CakeFlowerShop.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Web
@attribute [Authorize]
@rendermode InteractiveServer
@inject ApplicationDbContext DbContext
@inject CartService CartService
@inject IJSRuntime JS

<PageTitle>Blossom & Bake - Shop</PageTitle>

<div class="container mb-5" id="shop">
    <h2 class="section-title mt-5">All Products</h2>

    <div class="search-container mb-4">
        <div class="row justify-content-center">
            <div class="col-md-7">
                <div class="input-group search-box-wrapper">
                    <div class="search-box flex-grow-1">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" class="form-control" placeholder="Search for cakes, flowers..." 
                               value="@searchTerm" 
                               @oninput="OnSearchInput" 
                               @onkeydown="HandleKeyDown" />
                    </div>
                    <button class="btn btn-accent ms-2 px-4" @onclick="ApplySearch" style="border-radius: 50px;">
                        Search
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (products == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var product in FilteredProducts)
            {
                <div class="col-md-4 col-sm-6">
                    <div class="product-card">
                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "https://via.placeholder.com/300x250?text=No+Image" : product.ImageUrl)" class="product-img" alt="@product.Name" />
                        <div class="product-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h3 class="product-title">@product.Name</h3>
                                <span class="badge-category">@product.Category.ToString()</span>
                            </div>
                            <p class="product-desc">@product.Description</p>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <div class="product-price">₱@product.Price.ToString("0.00")</div>
                                <button class="btn btn-primary btn-sm px-3" @onclick="() => AddToCart(product)" style="z-index: 10; position: relative;">
                                    Add to Cart
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
@code {
    private List<Product>? products;
    private string searchTerm = "";
    private int addingProductId;

    private IEnumerable<Product> FilteredProducts
    {
        get
        {
            if (products == null) return Enumerable.Empty<Product>();
            if (string.IsNullOrWhiteSpace(searchTerm)) return products;

            var term = searchTerm.Trim().ToLower();
            return products.Where(p => 
                p.Name.ToLower().Contains(term) || 
                p.Category.ToString().ToLower().Contains(term) ||
                (term.EndsWith("s") && p.Name.ToLower().Contains(term.Substring(0, term.Length - 1))) || // Handle "tulips" matching "tulip"
                p.Description.ToLower().Contains(term)
            );
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CartService.InitializeAsync();
        products = await DbContext.Products.ToListAsync();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        StateHasChanged();
    }

    private void ApplySearch()
    {
        // This forces a re-evaluation of FilteredProducts and a UI refresh
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            ApplySearch();
        }
    }

    private async Task AddToCart(Product product)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to buy this?");
        if (!confirmed) return;

        CartService.AddToCart(product);
        StateHasChanged();
    }
}
