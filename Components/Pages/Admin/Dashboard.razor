@page "/admin"
@using CakeFlowerShop.Data
@using CakeFlowerShop.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Web
@attribute [Authorize(Roles = "Admin")]
@inject ApplicationDbContext DbContext

<PageTitle>Admin Dashboard</PageTitle>

<div class="container mt-4">
    <h2>Admin Dashboard</h2>
    <div class="row mt-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary mb-3 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">Total Products</h5>
                    <p class="card-text fs-2">@productsCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-success mb-3 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">Total Orders</h5>
                    <p class="card-text fs-2">@ordersCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-warning mb-3 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">Pending Orders</h5>
                    <p class="card-text fs-2">0</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-white bg-danger mb-3 shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">Total Revenue</h5>
                    <p class="card-text fs-2">₱0.00</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <h3>Products</h3>
        <button class="btn btn-primary mb-3">Add New Product</button>
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (products == null)
                {
                    <tr><td colspan="6" class="text-center">Loading...</td></tr>
                }
                else if (!products.Any())
                {
                    <tr><td colspan="6" class="text-center">No products found.</td></tr>
                }
                else
                {
                    @foreach (var p in products)
                    {
                        <tr>
                            <td>@p.Id</td>
                            <td>@p.Name</td>
                            <td>@p.Category</td>
                            <td>₱@p.Price.ToString("0.00")</td>
                            <td>@p.StockQuantity</td>
                            <td>
                                <button class="btn btn-sm btn-info text-white">Edit</button>
                                <button class="btn btn-sm btn-danger">Delete</button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private int productsCount = 0;
    private int ordersCount = 0;
    private List<Product>? products;

    protected override async Task OnInitializedAsync()
    {
        products = await DbContext.Products.ToListAsync();
        productsCount = products.Count;
        ordersCount = await DbContext.Orders.CountAsync();
    }
}
